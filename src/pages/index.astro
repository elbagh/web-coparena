---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SceneHorizon from "../components/SceneHorizon.astro";
import SceneForest from "../components/SceneForest.astro";
import { event, perks, pasos } from "../data/event";
import { absoluteUrl, site } from "../data/seo";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    inLanguage: "es",
    description: site.defaultDescription,
    sameAs: [event.instagram]
  },
  {
    "@context": "https://schema.org",
    "@type": "SportsEvent",
    name: event.name,
    description: event.claim,
    url: site.url,
    image: absoluteUrl(site.defaultImage),
    startDate: "2026-07-31",
    endDate: "2026-08-09",
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    eventStatus: "https://schema.org/EventScheduled",
    sport: "Beach volleyball",
    location: {
      "@type": "Place",
      name: "Playa de O Pozo",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Porto do Son",
        addressRegion: "A Coruña",
        addressCountry: "ES"
      }
    },
    organizer: {
      "@type": "Organization",
      name: event.name,
      url: site.url,
      email: event.email,
      sameAs: [event.instagram]
    }
  }
];
---

<BaseLayout structuredData={structuredData}>
  <div class="cursor-blob" data-cursor-blob aria-hidden="true"></div>
  <SiteHeader />
  <main>
    <Hero />

    <section class="band-sand band-pasos" id="torneo">
      <SectionHeading
        eyebrow="Cómo funciona"
        title="Pasos para apuntarse"
        text="De cero a jugar la Copa en cuatro pasos."
      />
      <ol class="pasos-flow">
        {
          pasos.map((paso, index) => (
            <li class="paso reveal" style={`--reveal-delay: ${index * 90}ms`}>
              <div class="paso-bubble">
                <span class="paso-num" aria-hidden="true">{index + 1}</span>
                <h3>{paso.titulo}</h3>
                <p>{paso.texto}</p>
                {paso.link && (
                  <a class="paso-link" href={paso.link.url}>
                    {paso.link.label}
                  </a>
                )}
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="band-sand band-venir" id="venir">
      <SectionHeading
        eyebrow="Para el público"
        title="¡Tienes que venir!"
        text="No es un torneo normal. Toca para ver qué hay."
      />
      <ul class="perk-list">
        {
          perks.map((perk, index) => (
            <li class="reveal" style={`--reveal-delay: ${index * 70}ms`}>
              <details class="perk-card" name="perks">
                <summary class="perk-chip">{perk.title}</summary>
                <div class="perk-body">
                  <p>{perk.detail}</p>
                  {perk.people && (
                    <div class="perk-people">
                      {perk.people.map((person) => (
                        <a class="perk-person" href={person.url} rel="noreferrer">
                          <img
                            src={person.photo}
                            alt={`Foto de ${person.handle}`}
                            loading="lazy"
                            width="144"
                            height="144"
                          />
                          <span>{person.handle}</span>
                        </a>
                      ))}
                    </div>
                  )}
                  {perk.detailAfter && <p>{perk.detailAfter}</p>}
                  {perk.link && (
                    <a class="perk-link" href={perk.link.url} rel="noreferrer">
                      {perk.link.label}
                    </a>
                  )}
                </div>
              </details>
            </li>
          ))
        }
      </ul>
    </section>

    <SceneForest />

    <section class="cta-band" id="jugar" aria-labelledby="cta-title">
      <SceneHorizon variant="sunset" dunes={false} />
      <div class="cta-content">
        <p class="eyebrow reveal">Inscripciones</p>
        <h2 id="cta-title" class="cta-title reveal" style="--reveal-delay: 90ms">Quiero jugar</h2>
        <p class="cta-text reveal" style="--reveal-delay: 180ms">
          Inscribe a tu equipo: 30 € por equipo, se pagan en el primer partido.
          Fechas: {event.dateStart} y {event.dateEnd} en {event.location}.
        </p>
        <div class="hero-actions cta-actions reveal" style="--reveal-delay: 270ms">
          <a class="button button-primary" href="/inscripcion/">Inscribir equipo</a>
          <a class="button button-secondary" href={event.instagram} rel="noreferrer">Instagram</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script is:inline src="/assets/site-interactions.js" defer></script>
</BaseLayout>
