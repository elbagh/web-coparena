---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SceneHorizon from "../components/SceneHorizon.astro";
import SceneForest from "../components/SceneForest.astro";
import { event, perks, pasos, inscripcion, donde } from "../data/event";
import { absoluteUrl, site, sameAs } from "../data/seo";

// Fechas del SportsEvent derivadas de la fuente única (event.phases) para que
// no puedan divergir del texto visible.
const eventStart = event.phases[0].startISO;
const eventEnd = event.phases[event.phases.length - 1].endISO;
const precioEquipo = String(parseInt(inscripcion.precio, 10));

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: site.name,
    url: site.url,
    logo: absoluteUrl("/assets/copa-arena-logo-blue-full.png"),
    email: event.email,
    sameAs
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    inLanguage: "es",
    description: site.defaultDescription,
    sameAs
  },
  {
    "@context": "https://schema.org",
    "@type": "SportsEvent",
    name: event.name,
    description: event.claim,
    url: site.url,
    image: absoluteUrl(site.defaultImage),
    startDate: eventStart,
    endDate: eventEnd,
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    eventStatus: "https://schema.org/EventScheduled",
    sport: "Beach volleyball",
    location: {
      "@type": "Place",
      name: donde.nombre,
      address: {
        "@type": "PostalAddress",
        streetAddress: donde.direccion.streetAddress,
        postalCode: donde.direccion.postalCode,
        addressLocality: donde.direccion.addressLocality,
        addressRegion: donde.direccion.addressRegion,
        addressCountry: donde.direccion.addressCountry
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: donde.coords.lat,
        longitude: donde.coords.lon
      }
    },
    offers: {
      "@type": "Offer",
      name: "Inscripción por equipo",
      price: precioEquipo,
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      url: absoluteUrl(inscripcion.url)
    },
    organizer: {
      "@type": "Organization",
      name: event.name,
      url: site.url,
      email: event.email,
      sameAs
    }
  }
];
---

<BaseLayout structuredData={structuredData}>
  <div class="cursor-blob" data-cursor-blob aria-hidden="true"></div>
  <SiteHeader />
  <main>
    <Hero />

    <section class="band-sand band-pasos" id="torneo">
      <SectionHeading
        eyebrow="Cómo funciona"
        title="Pasos para apuntarse"
        text="De cero a jugar la Copa en cuatro pasos."
      />
      <ol class="pasos-flow">
        {
          pasos.map((paso, index) => (
            <li class="paso reveal" style={`--reveal-delay: ${index * 90}ms`}>
              <div class="paso-bubble">
                <span class="paso-num" aria-hidden="true">{index + 1}</span>
                <h3>{paso.titulo}</h3>
                <p>{paso.texto}</p>
                {paso.link && (
                  <a class="paso-link" href={paso.link.url}>
                    {paso.link.label}
                  </a>
                )}
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="band-matches" id="partidos" data-public-matches>
      <SectionHeading
        eyebrow="Partidos"
        title="Horario y marcador"
        text="Cruces, horas, partidos en juego y resultados cerrados por la organizacion."
      />
      <p class="teams-status" data-matches-status aria-live="polite">Cargando calendario...</p>
      <div class="matches-bracket-wrap" data-matches-bracket hidden></div>
      <div class="public-match-list" data-matches-list hidden></div>
    </section>

    <section class="band-sand band-venir" id="venir">
      <SectionHeading
        eyebrow="Para el público"
        title="¡Tienes que venir!"
        text="No es un torneo normal. Toca para ver qué hay."
      />
      <ul class="perk-list">
        {
          perks.map((perk, index) => (
            <li class="reveal" style={`--reveal-delay: ${index * 70}ms`}>
              <details class="perk-card" name="perks">
                <summary class="perk-chip">{perk.title}</summary>
                <div class="perk-body">
                  <p>{perk.detail}</p>
                  {perk.people && (
                    <div class="perk-people">
                      {perk.people.map((person) => (
                        <a class="perk-person" href={person.url} rel="noreferrer">
                          <img
                            src={person.photo}
                            alt={`Foto de ${person.handle}`}
                            loading="lazy"
                            width="144"
                            height="144"
                          />
                          <span>{person.handle}</span>
                        </a>
                      ))}
                    </div>
                  )}
                  {perk.detailAfter && <p>{perk.detailAfter}</p>}
                  {perk.link && (
                    <a class="perk-link" href={perk.link.url} rel="noreferrer">
                      {perk.link.label}
                    </a>
                  )}
                </div>
              </details>
            </li>
          ))
        }
      </ul>
    </section>

    <SceneForest />

    <section class="cta-band" id="jugar" aria-labelledby="cta-title">
      <SceneHorizon variant="sunset" dunes={false} />
      <div class="cta-content">
        <p class="eyebrow reveal">Inscripciones</p>
        <h2 id="cta-title" class="cta-title reveal" style="--reveal-delay: 90ms">Quiero jugar</h2>
        <p class="cta-text reveal" style="--reveal-delay: 180ms">
          Inscribe a tu equipo: 30 € por equipo, se pagan en el primer partido.
          Fase de grupos: {event.phases[0].dates}. Fase final: {event.phases[1].dates}. En {event.location}.
        </p>
        <div class="hero-actions cta-actions reveal" style="--reveal-delay: 270ms">
          <a class="button button-primary" href="/inscripcion/">Inscribir equipo</a>
          <a class="button button-secondary" href={event.instagram} rel="noreferrer">Instagram</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script is:inline src="/assets/site-interactions.js" defer></script>
  <script is:inline src="/assets/match-utils.js" defer></script>
  <script is:inline src="/assets/matches-board.js" defer></script>
</BaseLayout>
