---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Admin | La Copa Arena"
  description="Panel privado de administración de La Copa Arena."
  noindex={true}
>
  <SiteHeader />

  <main class="legal-page admin-page">
    <section class="legal-hero">
      <p class="eyebrow reveal">Privado</p>
      <h1 class="reveal" style="--reveal-delay: 90ms">Panel de administración</h1>
      <p class="reveal" style="--reveal-delay: 180ms">
        Gestión interna de equipos, jugadores y camisetas. Solo las cuentas marcadas como administradoras pueden ver estos datos.
      </p>
    </section>

    <section class="auth-card reveal" style="--reveal-delay: 220ms" data-auth-loading>
      <h2>Comprobando sesión...</h2>
    </section>

    <section class="auth-card reveal" style="--reveal-delay: 220ms" data-auth-logged-out hidden>
      <h2>Entra con Google</h2>
      <p>El panel solo se abre si tu usuario está marcado como administrador en la base de datos.</p>
      <p class="auth-error" data-auth-error hidden></p>
      <div class="google-login" data-google-login></div>
    </section>

    <section class="admin-shell reveal" style="--reveal-delay: 280ms" data-auth-logged-in data-admin hidden>
      <div class="teams-panel" data-admin-loading>
        <p class="teams-status">Cargando panel...</p>
      </div>

      <div class="form-banner" role="alert" data-admin-error hidden></div>

      <section class="admin-stats" data-admin-stats hidden aria-label="Resumen del torneo"></section>

      <section class="admin-grid" data-admin-content hidden>
        <article class="teams-panel admin-panel admin-panel-wide" data-admin-matches>
          <div class="admin-panel-head">
            <div>
              <p class="eyebrow">Partidos</p>
              <h2>Sorteo y marcador</h2>
              <p data-admin-status>Cargando equipos y partidos...</p>
            </div>
            <div class="admin-actions">
              <button class="add-player" type="button" data-load-teams>Actualizar equipos</button>
              <button class="button button-primary" type="button" data-draw>Sortear emparejamientos</button>
              <button class="button button-secondary" type="button" data-confirm-draw hidden>Confirmar sorteo</button>
            </div>
          </div>
          <form class="manual-team-form" data-match-team-form>
            <label class="field">
              <span>Equipo manual</span>
              <input type="text" name="team" placeholder="Nombre del equipo" autocomplete="off" />
            </label>
            <button class="add-player" type="submit">Anadir</button>
          </form>
          <div class="admin-team-pool" data-team-pool aria-live="polite"></div>
          <div class="matches-bracket-wrap" data-admin-bracket hidden></div>
          <div class="admin-match-list" data-match-list></div>
        </article>

        <article class="teams-panel admin-panel">
          <div class="admin-panel-head">
            <div>
              <p class="eyebrow">Equipos</p>
              <h2>Equipos registrados</h2>
            </div>
            <button type="button" class="add-player" data-admin-refresh>Actualizar</button>
          </div>
          <div class="admin-list" data-admin-teams></div>
        </article>

        <article class="teams-panel admin-panel">
          <div class="admin-panel-head">
            <div>
              <p class="eyebrow">Camisetas</p>
              <h2>Reservas</h2>
            </div>
          </div>
          <form class="admin-shirt-form" data-admin-shirt-form novalidate>
            <div class="form-banner" data-admin-shirt-banner hidden></div>
            <div class="shirts-form-grid">
              <div class="field">
                <label for="admin-shirt-name">Nombre</label>
                <input id="admin-shirt-name" name="nombre" type="text" maxlength="80" autocomplete="name" data-admin-shirt-field="nombre" />
                <p class="field-error" data-admin-shirt-error="nombre" hidden></p>
              </div>
              <div class="field">
                <label for="admin-shirt-size">Talla</label>
                <select id="admin-shirt-size" name="talla" data-admin-shirt-field="talla">
                  <option value="">Elige talla</option>
                  <option value="XS">XS</option>
                  <option value="S">S</option>
                  <option value="M">M</option>
                  <option value="L">L</option>
                  <option value="XL">XL</option>
                  <option value="XXL">XXL</option>
                </select>
                <p class="field-error" data-admin-shirt-error="talla" hidden></p>
              </div>
              <div class="field">
                <label for="admin-shirt-quantity">Cantidad</label>
                <input id="admin-shirt-quantity" name="cantidad" type="number" min="1" max="10" step="1" value="1" data-admin-shirt-field="cantidad" />
                <p class="field-error" data-admin-shirt-error="cantidad" hidden></p>
              </div>
              <div class="field shirts-notes">
                <label for="admin-shirt-notes">Notas <span class="field-opt">opcional</span></label>
                <textarea id="admin-shirt-notes" name="notas" rows="3" maxlength="240" data-admin-shirt-field="notas"></textarea>
                <p class="field-error" data-admin-shirt-error="notas" hidden></p>
              </div>
            </div>
            <div class="admin-shirt-form-actions">
              <button type="submit" class="form-submit" data-admin-shirt-submit>Añadir reserva</button>
            </div>
          </form>
          <div class="admin-list" data-admin-shirts></div>
        </article>
      </section>
    </section>
  </main>

  <dialog class="match-dialog" data-match-dialog>
    <form method="dialog" class="match-dialog-close">
      <button type="submit" aria-label="Cerrar">x</button>
    </form>
    <div class="match-dialog-body" data-dialog-body></div>
  </dialog>

  <SiteFooter />

  <script is:inline src="https://accounts.google.com/gsi/client" async defer></script>
  <script is:inline src="/assets/site-interactions.js" defer></script>
  <script is:inline src="/assets/match-utils.js" defer></script>
  <script is:inline src="/assets/admin.js" defer></script>
  <script is:inline src="/assets/admin-matches.js" defer></script>
</BaseLayout>
