---
import LogoMark from "./LogoMark.astro";
import { event, socials } from "../data/event";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-main">
    <div class="footer-brand">
      <a class="footer-logo" href="/" aria-label="La Copa Arena inicio">
        <LogoMark />
      </a>
      <p>
        El campeonato de vóley playa de Playa O Pozo. Cada verano, en la arena.
      </p>
      <div class="footer-social">
        <a href={socials.instagram} aria-label="Instagram" rel="noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="2"></rect>
            <circle cx="12" cy="12" r="4.2" fill="none" stroke="currentColor" stroke-width="2"></circle>
            <circle cx="17.3" cy="6.7" r="1.4" fill="currentColor"></circle>
          </svg>
        </a>
        <a href={socials.tiktok} aria-label="TikTok" rel="noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M16.6 5.82A4.28 4.28 0 0 1 15.54 3h-3.09v12.4a2.59 2.59 0 1 1-2.59-2.59c.27 0 .53.04.78.12v-3.14a5.73 5.73 0 1 0 4.9 5.61V9.66a7.35 7.35 0 0 0 4.3 1.38V7.95a4.28 4.28 0 0 1-3.24-2.13Z"
            ></path>
          </svg>
        </a>
        <a href={socials.whatsapp} aria-label="WhatsApp" rel="noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M12.04 2a9.9 9.9 0 0 0-8.4 15.16L2 22l4.97-1.6A9.9 9.9 0 1 0 12.04 2Zm0 18.02a8.1 8.1 0 0 1-4.13-1.13l-.3-.18-2.95.95.96-2.87-.2-.3a8.12 8.12 0 1 1 6.62 3.53Zm4.45-6.08c-.24-.12-1.43-.7-1.65-.79-.22-.08-.38-.12-.55.12-.16.24-.63.79-.77.95-.14.16-.28.18-.53.06-.24-.12-1.02-.38-1.95-1.2-.72-.64-1.2-1.43-1.35-1.67-.14-.24-.01-.37.11-.5.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.55-1.31-.75-1.8-.2-.47-.4-.4-.55-.41h-.47c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.7 2.6 4.11 3.64.57.25 1.02.4 1.37.51.58.18 1.1.16 1.51.1.46-.07 1.43-.58 1.63-1.15.2-.56.2-1.04.14-1.15-.06-.1-.22-.16-.46-.28Z"
            ></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer-column">
      <h2>Contacto</h2>
      <a href={`mailto:${event.email}`}>{event.email}</a>
      <span>{event.location}</span>
    </div>

    <div class="footer-column">
      <h2>Evento</h2>
      <a href="/#fechas">Fechas</a>
      <a href="/#venir">Qué hay</a>
      <a href="/inscripcion/">Inscripciones</a>
      <a href="/equipos/">Equipos</a>
      <a href={socials.camisetas} rel="noreferrer">Camisetas</a>
    </div>

    <div class="footer-column">
      <h2>Legal</h2>
      <a href="/aviso-legal/">Aviso legal</a>
      <a href="/privacidad/">Privacidad</a>
      <a href="/cookies/">Cookies</a>
    </div>
  </div>

  <div class="footer-bottom">
    <span>&copy; {year} La Copa Arena</span>
    <span>Hecha en la arena de O Pozo.</span>
  </div>
</footer>
