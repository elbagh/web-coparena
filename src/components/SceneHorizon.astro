---
const { variant = "morning", dunes = true } = Astro.props;
---

<div class:list={["scene", "scene-horizon", `scene-${variant}`]} data-scene aria-hidden="true">
  <div class="scene-sky"></div>
  <div class="scene-sun" data-parallax="0.55"></div>

  <svg class="scene-louro-far" data-parallax="0.4" viewBox="0 0 420 120" preserveAspectRatio="none">
    <path
      d="M0 120 L0 76 L92 34 L146 64 L204 42 L420 110 L420 120 Z"
      stroke-linejoin="round"
      stroke-width="6"
    ></path>
  </svg>

  <svg class="scene-louro" data-parallax="0.3" viewBox="0 0 1440 200" preserveAspectRatio="none">
    <path
      d="M0 200 L0 190 L640 190 L980 32 L1128 116 L1206 70 L1440 174 L1440 200 Z"
      stroke-linejoin="round"
      stroke-width="12"
    ></path>
  </svg>

  <svg class="scene-sea" data-parallax="0.16" viewBox="0 0 1440 320" preserveAspectRatio="none">
    <path
      class="sea-base"
      d="M0 6 C 240 0 480 10 720 6 C 960 2 1200 10 1440 6 L1440 320 L0 320 Z"
    ></path>
    <path
      class="sea-glint"
      d="M0 60 C 240 52 480 68 720 60 C 960 52 1200 68 1440 60 L1440 66 C 1200 74 960 58 720 66 C 480 74 240 58 0 66 Z"
    ></path>
    <path
      class="sea-glint"
      d="M0 130 C 260 122 500 138 740 130 C 980 122 1220 138 1440 130 L1440 135 C 1220 143 980 127 740 135 C 500 143 260 127 0 135 Z"
    ></path>
    <path
      class="sea-glint"
      d="M0 210 C 220 202 460 216 720 209 C 980 202 1220 217 1440 210 L1440 214 C 1220 221 980 206 720 213 C 460 220 220 206 0 214 Z"
    ></path>
  </svg>

  {
    dunes && (
      <Fragment>
        <svg
          class="scene-dune scene-dune-far"
          data-parallax="0.08"
          viewBox="0 0 1440 160"
          preserveAspectRatio="none"
        >
          <path d="M0 160 L0 70 C 200 34 430 86 660 66 C 890 46 1110 88 1300 60 C 1360 52 1410 58 1440 64 L1440 160 Z" />
        </svg>
        <svg class="scene-dune scene-dune-near" viewBox="0 0 1440 150" preserveAspectRatio="none">
          <path d="M0 150 L0 78 C 250 40 480 92 740 72 C 1000 52 1220 96 1440 62 L1440 150 Z" />
        </svg>
      </Fragment>
    )
  }

  <div class="scene-grain"></div>
</div>
