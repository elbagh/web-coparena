---
import { event } from "../data/event";
---

<section class="hero" aria-labelledby="hero-title">
  <img
    class="hero-art"
    src="/assets/copa-arena-hero-watercolor.png"
    alt="Partido de volley playa al atardecer en la arena, tratado en acuarela"
    loading="eager"
    decoding="async"
  />
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <p class="eyebrow hero-eyebrow"><a href="/donde-estamos/">{event.location}</a></p>
    <p class="hero-name">{event.name}</p>
    <h1 id="hero-title" class="hero-dates">
      {
        event.phases.map((phase, index) => (
          <span class={`date-line${index === 1 ? " date-line-end" : ""}`}>
            <span class="date-phase-label">{phase.label}</span>
            <span class="date-phase-date">{phase.dates}</span>
          </span>
        ))
      }
    </h1>
    <div class="hero-claims">
      <p class="hero-claim">{event.claim}</p>
    </div>
    <div class="hero-actions">
      <a class="button button-primary" href="#jugar">¡Quiero jugar!</a>
      <a class="button button-secondary" href="#venir">¡Quiero ir!</a>
    </div>
  </div>
</section>
