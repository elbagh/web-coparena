---
import Trofeo from "./Trofeo.astro";
import { premios } from "../data/event";

// premios llega en orden de clasificación [1º, 2º, 3º, 4º].
const [primero, segundo, tercero, cuarto] = premios;
// El podio se pinta 2 – 1 – 3 (el campeón en el centro, más alto).
const escalones = [
  { premio: segundo, place: "2" },
  { premio: primero, place: "1" },
  { premio: tercero, place: "3" }
];
---

<div
  class="podio"
  role="img"
  aria-label="Reparto del bote: 1º 50%, 2º 25%, 3º 15% y medallas, 4º las gracias, más un 10% para los premios secundarios."
>
  <ol class="podio-steps" aria-hidden="true">
    {
      escalones.map(({ premio, place }) => (
        <li class="podio-col" data-place={place} style={`--alt: ${premio.alt}`}>
          <div class="podio-cima">
            {place === "1" && <Trofeo class="podio-trofeo" />}
            {place === "3" && (
              <svg class="podio-medalla" viewBox="0 0 40 54" aria-hidden="true">
                <path d="M12 2 L21 24 L7 24 Z" class="medal-ribbon" />
                <path d="M28 2 L33 24 L19 24 Z" class="medal-ribbon" />
                <circle cx="20" cy="36" r="15" class="medal-disc" />
                <circle cx="20" cy="36" r="7.5" class="medal-inner" />
              </svg>
            )}
            <span class="podio-badge">{premio.pct}</span>
          </div>
          <div class="podio-block">
            <span class="podio-puesto">{premio.puesto}</span>
          </div>
        </li>
      ))
    }
  </ol>

  <p class="podio-base" aria-hidden="true">
    <span class="podio-base-num">{cuarto.puesto}</span>
    {cuarto.titulo}
  </p>

  <p class="podio-ribbon">+10% del bote → premios secundarios</p>

  <dl class="podio-detalle">
    {
      premios.map((premio) => (
        <div class="podio-detalle-item">
          <dt>
            <span class="podio-detalle-puesto">{premio.puesto}</span>
            {premio.titulo}
            {premio.pct && <span class="podio-detalle-pct">{premio.pct}</span>}
          </dt>
          <dd>{premio.detalle}</dd>
        </div>
      ))
    }
  </dl>
</div>
