---
import LogoMark from "./LogoMark.astro";

const navItems = [
  { href: "/donde-estamos/", label: "Dónde estamos" },
  { href: "/equipos/", label: "Equipos" },
  { href: "/mi-equipo/", label: "Mi equipo" }
];
---

<header class="site-header" aria-label="Cabecera principal">
  <div class="header-peak" aria-hidden="true">
    <svg viewBox="0 0 260 120" preserveAspectRatio="xMidYMax meet">
      <path
        d="M6 120 L80 22 L118 64 L140 40 L254 120 Z"
        stroke-linejoin="round"
        stroke-width="10"
      ></path>
    </svg>
  </div>

  <a class="brand" href="/" aria-label="La Copa Arena inicio">
    <span class="brand-mark"><LogoMark compact /></span>
    <span>La Copa Arena</span>
  </a>

  <nav class="nav-links" aria-label="Navegación principal">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>

  <a class="header-join" href="/inscripcion/">
    <svg class="join-ball" viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="12" cy="12" r="9.2" fill="none" stroke="currentColor" stroke-width="2.1"></circle>
      <path
        d="M3.4 8.7c5.3 2.3 11.9 2.3 17.2 0"
        fill="none"
        stroke="currentColor"
        stroke-width="2.1"
        stroke-linecap="round"
      ></path>
      <path
        d="M12 2.9c-4.3 5.3-4.3 12.9 0 18.2"
        fill="none"
        stroke="currentColor"
        stroke-width="2.1"
        stroke-linecap="round"
      ></path>
    </svg>
    <span>Inscribirse</span>
  </a>

  <details class="mobile-menu" data-mobile-menu>
    <summary aria-label="Abrir menú de navegación">
      <span class="mobile-menu-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
      <span>Menú</span>
    </summary>
    <nav class="mobile-menu-panel" aria-label="Navegación móvil">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      <a class="mobile-menu-join" href="/inscripcion/">Inscribirse</a>
    </nav>
  </details>
</header>
