---
import "@fontsource/titan-one";
import "../styles/global.css";

const {
  title = "La Copa Arena | Volley playa en Playa O Pozo",
  description = "La Copa Arena: el mejor campeonato de volley playa de Playa O Pozo. Del 31 de julio al 5 de agosto en Porto do Son.",
  noindex = false
} = Astro.props;

const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || "";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    {googleClientId && <meta name="google-client-id" content={googleClientId} />}
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/assets/copa-arena-favicon.png" type="image/png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
