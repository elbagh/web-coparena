---
import "@fontsource/titan-one";
import "../styles/global.css";

const {
  title = "La Copa Arena | Vóley playa en Playa O Pozo",
  description = "La Copa Arena: el mejor campeonato de vóley playa de Playa O Pozo. Del 31 de julio al 5 de agosto en Porto do Son."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/assets/copa-arena-favicon.png" type="image/png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
