{
  "name": "la-copa-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro check && astro build",
    "build:worker": "wrangler pages functions build --outdir=.worker",
    "deploy:worker": "npm run build:worker && wrangler deploy",
    "deploy": "npm run build && npm run deploy:worker",
    "preview": "astro preview --host 127.0.0.1"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@fontsource/titan-one": "^5.2.8",
    "astro": "^5.13.5",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "wrangler": "^4.110.0"
  }
}
